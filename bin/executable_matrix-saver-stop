#!/usr/bin/env bash
set -euo pipefail

PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/sway-matrix-saver.pid"

if [[ -f "${PID_FILE}" ]]; then
  pid="$(cat "${PID_FILE}")"
  if [[ -n "${pid}" ]]; then
    kill "${pid}" 2>/dev/null || true
  fi
  rm -f "${PID_FILE}"
fi

pkill -x sway-matrix-saver 2>/dev/null || true
