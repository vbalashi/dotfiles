#!/usr/bin/env bash
set -euo pipefail

LOCK_DELAY="${MATRIX_LOCK_DELAY_SEC:-1.2}"
PID_FILE="${XDG_RUNTIME_DIR:-/tmp}/sway-matrix-saver.pid"
STARTED_HERE=0

if [[ -f "${PID_FILE}" ]]; then
  pid="$(cat "${PID_FILE}")"
  if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
    STARTED_HERE=0
  else
    rm -f "${PID_FILE}"
    "${HOME}/bin/matrix-saver-start"
    STARTED_HERE=1
  fi
else
  "${HOME}/bin/matrix-saver-start"
  STARTED_HERE=1
fi

if [[ "${STARTED_HERE}" -eq 1 ]]; then
  sleep "${LOCK_DELAY}"
fi

"${HOME}/bin/matrix-saver-stop"

if [[ "${MATRIX_LOCK_TEST:-0}" == "1" ]]; then
  printf 'matrix-lock test mode: swaylock %s\n' "$*"
  exit 0
fi

# Force the first configured keyboard layout (`us` in Sway config) for lock entry.
swaymsg 'input type:keyboard xkb_switch_layout 0' >/dev/null 2>&1 || true

exec swaylock "$@"
