# ---------------------------------------------------------------------------
# AdGuard VPN CLI completion
# ---------------------------------------------------------------------------
_adguardvpn_cli_locations() {
  adguardvpn-cli list-locations --bash-completion "$1" 2>/dev/null
}

_adguardvpn_cli_complete() {
  local cur prev subcmd
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"
  subcmd="${COMP_WORDS[1]}"

  if [[ "$prev" == "-l" || "$prev" == "--location" ]]; then
    COMPREPLY=($(compgen -W "$(_adguardvpn_cli_locations "$cur")" -- "$cur"))
    return
  fi

  if [[ $COMP_CWORD -le 1 ]]; then
    COMPREPLY=($(compgen -W "login logout list-locations connect disconnect status license config check-update export-logs update site-exclusions -h --help --help-all -v --version" -- "$cur"))
    return
  fi

  case "$subcmd" in
    connect)
      COMPREPLY=($(compgen -W "-l --location -f --fastest -v --verbose --no-fork --ppid-file --pid-file -y --yes -4 --ipv4only -6 --ipv6only --log-to-file --no-progress --boot" -- "$cur"))
      ;;
    export-logs)
      COMPREPLY=($(compgen -W "-o --output -f --force" -- "$cur"))
      ;;
    update)
      COMPREPLY=($(compgen -W "-v --verbose -y --yes" -- "$cur"))
      ;;
    list-locations)
      COMPREPLY=($(compgen -W "--bash-completion" -- "$cur"))
      ;;
    config)
      COMPREPLY=($(compgen -W "set-mode set-dns set-socks-port set-socks-host set-socks-username set-socks-password clear-socks-auth set-change-system-dns set-tun-routing-mode create-route-script set-crash-reporting set-telemetry set-update-channel set-protocol set-post-quantum set-show-hints set-debug-logging set-show-notifications set-bound-if-override show" -- "$cur"))
      ;;
    site-exclusions)
      COMPREPLY=($(compgen -W "add remove show clear mode" -- "$cur"))
      ;;
  esac
}
