# --- scpp: scp через SOCKS + умный completion ---

# 1) Обёртка и алиас
scp_via_proxy() {
  scp -o ProxyCommand='nc -x 192.168.178.61:1080 %h %p' "$@"
}
alias scpp='scp_via_proxy'

# 2) Подтягиваем базовые функции bash-completion
# (для _init_completion, _filedir, _known_hosts)
type _init_completion >/dev/null 2>&1 || {
  [ -r /usr/share/bash-completion/bash_completion ] && \
    . /usr/share/bash-completion/bash_completion
}

# 3) Если есть ssh-completion — подключим (для удалённых путей)
if ! declare -F _ssh >/dev/null; then
  type __load_completion >/dev/null 2>&1 && __load_completion ssh 2>/dev/null || true
  [ -r /usr/share/bash-completion/completions/ssh ] && \
    . /usr/share/bash-completion/completions/ssh
fi

# 4) Наш комплитер
_scpp_complete() {
  local cur prev words cword
  _init_completion -s || return

  # Первый аргумент без опций -> подсказываем хосты (и локальные тоже при желании)
  if (( cword == 1 )) && [[ "$cur" != -* ]]; then
    # известные хосты из ~/.ssh/config и known_hosts
    _known_hosts -a -- "$cur"
    return
  fi

  # Если похоже на удалённый синтаксис (user@ / host: )
  if [[ "$cur" == *@* || "$cur" == *:* ]]; then
    # Если есть системный ssh-комплитер — делегируем ему, маскируемся под scp
    if declare -F _ssh >/dev/null; then
      local _save_WORDS=("${COMP_WORDS[@]}")
      local _save_LINE=$COMP_LINE
      COMP_WORDS[0]=scp
      COMP_LINE="scp${_save_LINE#${_save_WORDS[0]}}"
      _ssh "$@"
      return
    fi
    # Иначе хотя бы подскажем хосты
    _known_hosts -a -- "$cur"
    return
  fi

  # По умолчанию — локальные файлы/директории
  _filedir
}

# 5) Вешаем комплитер на алиас и функцию
complete -o default -o nospace -F _scpp_complete scpp
complete -o default -o nospace -F _scpp_complete scp_via_proxy
