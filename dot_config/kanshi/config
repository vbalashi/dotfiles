# Docked: laptop + external monitor via USB-C dock
# Adjust external output name/resolution after `swaymsg -t get_outputs`
profile docked {
    output eDP-1 enable scale 1.25 position 0,0
    output "DP-1" enable position 1536,0
}

# Undocked: laptop only
profile undocked {
    output eDP-1 enable scale 1.25
}

# Lid closed: external only
profile lid-closed {
    output eDP-1 disable
    output "DP-1" enable
}
