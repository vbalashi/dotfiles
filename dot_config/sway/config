# Sway config — ThinkPad X1 Carbon Gen 6
# Read `man 5 sway` for reference

### Variables
set $mod Mod4
set $term ghostty
set $menu fuzzel
set $ws1 1:term
set $ws2 2:web
set $ws3 3:util
set $ws4 4:docs
set $ws5 5:chat
set $ws6 6:misc
set $ws7 7:code
set $ws8 8:note
set $ws9 9:chr
set $ws10 10:rec

### Appearance
gaps inner 4
gaps outer 2
default_border pixel 2

# Catppuccin Mocha accents
client.focused          #89b4fa #89b4fa #1e1e2e #f5c2e7 #89b4fa
client.focused_inactive #45475a #45475a #cdd6f4 #45475a #45475a
client.unfocused        #313244 #313244 #a6adc8 #313244 #313244
client.urgent           #f38ba8 #f38ba8 #1e1e2e #f38ba8 #f38ba8

# Cursor
seat seat0 xcursor_theme Adwaita 24

### GTK theming
exec_always {
    /home/khrustal/.local/bin/sway-apply-appearance-state
}

### Output
output eDP-1 scale 1.5

### Input
input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
    middle_emulation enabled
}

input type:keyboard {
    xkb_layout us,ru
    xkb_options grp:alt_shift_toggle,caps:super
}

### Idle & lock
exec_always sh -lc 'nohup /home/khrustal/bin/sway-idle-start >/dev/null 2>&1 &'
exec_always ~/bin/sway-caffeinate init

### Autostart
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec mako
exec_always sh -c 'pkill -x kanshi; exec kanshi'
exec XDG_CURRENT_DESKTOP=sway 1password --silent
exec nm-applet --indicator
exec blueman-applet
exec wl-paste --watch cliphist store
include ~/.config/sway/conf.d/*.conf
exec_always sh -c 'swaymsg "rename workspace number 1 to \"1:term\"; rename workspace number 2 to \"2:web\"; rename workspace number 3 to \"3:util\"; rename workspace number 4 to \"4:docs\"; rename workspace number 5 to \"5:chat\"; rename workspace number 6 to \"6:misc\"; rename workspace number 7 to \"7:code\"; rename workspace number 8 to \"8:note\"; rename workspace number 9 to \"9:chr\"; rename workspace number 10 to \"10:rec\"" >/dev/null 2>&1'

### Waybar
exec_always sh -c 'pkill -x waybar; exec waybar'

### Key bindings — basics
bindsym $mod+Return exec $term
bindsym Ctrl+Shift+space exec sh -c 'swaymsg [app_id="1password"] move container to workspace current, focus >/dev/null 2>&1; XDG_CURRENT_DESKTOP=sway 1password --quick-access'
bindsym $mod+grave exec /home/khrustal/.local/bin/toggle-quake-terminal
bindsym $mod+d exec $menu
bindsym $mod+Shift+q kill
floating_modifier $mod normal
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaynag -t warning \
    -m 'Exit sway?' -B 'Yes' 'swaymsg exit'
bindsym $mod+Escape exec sh -lc 'MATRIX_LOCK_DELAY_SEC=2.5 ~/bin/matrix-lock -f -c 1e1e2e'
bindsym $mod+Ctrl+n exec /home/khrustal/.local/bin/theme-mode toggle
bindsym $mod+Ctrl+i exec ~/bin/sway-caffeinate toggle
bindsym $mod+Ctrl+Shift+i exec ~/bin/sway-caffeinate for 60

### Navigation
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

### Move windows
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

### Workspaces
bindsym $mod+1 exec /home/khrustal/bin/sway-workspace-focus 1
bindsym $mod+2 exec /home/khrustal/bin/sway-workspace-focus 2
bindsym $mod+3 exec /home/khrustal/bin/sway-workspace-focus 3
bindsym $mod+4 exec /home/khrustal/bin/sway-workspace-focus 4
bindsym $mod+5 exec /home/khrustal/bin/sway-workspace-focus 5
bindsym $mod+6 exec /home/khrustal/bin/sway-workspace-focus 6
bindsym $mod+7 exec /home/khrustal/bin/sway-workspace-focus 7
bindsym $mod+8 exec /home/khrustal/bin/sway-workspace-focus 8
bindsym $mod+9 exec /home/khrustal/bin/sway-workspace-focus 9
bindsym $mod+0 exec /home/khrustal/bin/sway-workspace-focus 10
bindgesture swipe:3:left exec /home/khrustal/bin/sway-workspace-cycle next
bindgesture swipe:3:right exec /home/khrustal/bin/sway-workspace-cycle prev
bindgesture swipe:4:left exec /home/khrustal/bin/sway-workspace-cycle next
bindgesture swipe:4:right exec /home/khrustal/bin/sway-workspace-cycle prev

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

### Layout
bindsym $mod+b splith
bindsym $mod+backslash splitv
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space input type:keyboard xkb_switch_layout next
bindsym $mod+Tab focus mode_toggle
bindsym $mod+a focus parent

### Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

### Resize mode
mode "resize" {
    bindsym h resize shrink width 10px
    bindsym j resize grow height 10px
    bindsym k resize shrink height 10px
    bindsym l resize grow width 10px
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

### Media & brightness
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl set +5%
bindsym XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous

### Screenshots (grim + slurp → satty)
bindsym Print exec grim -t ppm -g "$(slurp)" - | satty -f -
bindsym Shift+Print exec grim -t ppm - | satty -f -

### Screen recording (wf-recorder + slurp)
bindsym $mod+Shift+r exec sh -c 'if pgrep -x wf-recorder > /dev/null; then pkill -INT wf-recorder && notify-send "Recording saved"; else wf-recorder -g "$(slurp)" -f ~/Videos/recording-$(date +%Y%m%d-%H%M%S).mp4 & notify-send "Recording started"; fi'

### Clipboard history
bindsym $mod+v exec cliphist list | fuzzel -d | cliphist decode | wl-copy

### Display scale reset
bindsym $mod+Ctrl+0 exec sh -c 'swaymsg output eDP-1 scale 1.5 && notify-send "Display scale reset to 1.5"'

### Voice dictation (voxtype)
bindsym --no-repeat $mod+Shift+v exec voxtype record toggle

### Float rules
for_window [app_id="pavucontrol"] floating enable
for_window [app_id="nm-connection-editor"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [app_id="nm-applet"] floating enable
for_window [app_id="org.gnome.Nautilus"] floating enable, move position center
for_window [class="^Org.gnome.Nautilus$"] floating enable, move position center
for_window [class="^Nautilus$"] floating enable, move position center
for_window [app_id="org.gnome.Loupe"] floating enable, move position center
for_window [class="^loupe$"] floating enable, move position center
for_window [class="^Loupe$"] floating enable, move position center
for_window [title="^Quake Terminal$"] floating enable, resize set width 100 ppt height 40 ppt, move position 0 0, move scratchpad
for_window [window_role="pop-up"] floating enable
for_window [window_role="dialog"] floating enable
for_window [window_type="dialog"] floating enable

### Workspace rules
assign [app_id="com.mitchellh.ghostty"] $ws1
assign [class="^Ghostty$"] $ws1
assign [app_id="vivaldi-stable"] $ws2
assign [class="^Vivaldi-stable$"] $ws2
assign [app_id="code"] $ws7
assign [class="^Code$"] $ws7
assign [app_id="obsidian"] $ws8
assign [class="^obsidian$"] $ws8
assign [app_id="google-chrome"] $ws9
assign [app_id="com.google.Chrome"] $ws9
assign [class="^Google-chrome$"] $ws9
assign [app_id="com.obsproject.Studio"] $ws10
assign [class="^obs$"] $ws10

### Inhibit idle on fullscreen
for_window [app_id="firefox"] inhibit_idle fullscreen
for_window [app_id="vlc"] inhibit_idle fullscreen

include /etc/sway/config.d/*
